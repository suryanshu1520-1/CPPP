# Ignore everything
*

# Allow folders so Git can scan them
!*/

# Allow markdown files
!*.md

# Allow netlify.toml
!netlify.toml

# Allow .gitignore itself
!.gitignore

# Allow source code files
!*.py
!*.js
!*.jsx
!*.ts
!*.tsx
!*.css
!*.json
!*.mjs
!*.toml
!*.sql
!*.html

# Allow specific config files
!*.env.local
!.prettierrc*
!.eslintrc*
!tailwind.config.*
!postcss.config.*
!next.config.*
!tsconfig.json
!jsconfig.json
!package-lock.json
!*.config.mjs
!*.config.js

# Always ignore sensitive files
*.env
!.env.local
*.db
*.sqlite
node_modules/
.next/
.nuxt/
dist/
build/
*.log

# Ignore generated SQL output files (too large for git)
scripts/sql_output/
*.tmp

# AutoClaw KDream data
.autoclaw/